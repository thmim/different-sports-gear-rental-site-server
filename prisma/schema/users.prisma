model Users {
    id String @id @default(uuid())
    name String
    email String @unique
    password String
    role Role @default(CUSTOMER)
    status UserStatus @default(ACTIVE)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    gearItems Gearitems[]
    reviews Reviews[]
    rentalOrders RentalOrder[]
    @@map("users")
}